order += "cpu_usage"
order += "memory"
order += "disk /"
order += "wireless _first_"
order += "battery all"
order += "volume master"
order += "tztime local"


cpu_usage {
    format = "CPU: %usage"
}

memory {
    format = "RAM: %used"
}

tztime local {
    format = "%Y-%m-%d %H:%M"
}

volume master {
        format = "♪: %volume"
        format_muted = "♪: muted (%volume)"
        device = "default"
}
